# ============================================================
# Klinik Kesehatan GPIB Bukit Zaitun — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# ── Supabase / PostgreSQL ───────────────────────────────────
# Option A (recommended): Full Supabase connection string
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:479IwBJ7V21qxHsW@db.dmdeuzkojydiesfmihxw.supabase.co:5432/postgres

# Option B: Individual credentials (used if DATABASE_URL is not set)
# SQL_HOST=db.<project-ref>.supabase.co
# SQL_USER=postgres
# SQL_PASSWORD=your_supabase_db_password
# SQL_DB_NAME=postgres
# SQL_PORT=5432
# SQL_SSL=true

# ── Google OAuth (GIS) ─────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Type: OAuth 2.0 Client ID  →  Web application
# Authorised JavaScript origins: http://localhost:3000  (add prod URL too)
# Authorised redirect URIs: (leave blank for GIS One-Tap / implicit flow)

# Client ID — also set as VITE_GOOGLE_CLIENT_ID so Vite exposes it to the browser
GOOGLE_CLIENT_ID=624496688412-tkqk0sirjv3nb26c1c92f467robmr8k9.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# ── Access Control ─────────────────────────────────────────
# The email address that always has ADMIN + DOCTOR access regardless of DB entries
MASTER_ADMIN_EMAIL=fritssigerdkayadoe@gmail.com

# ── Gemini AI (optional) ───────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# If unset, the app falls back to a built-in mock triage simulator
GEMINI_API_KEY=AIza...

# ── Runtime ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
